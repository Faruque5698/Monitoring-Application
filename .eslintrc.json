{
  "env": {
    "node": true,
    "es2021": true,
    "commonjs": true
  },
  "extends": ["airbnb-base", "plugin:prettier/recommended"],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "plugins": ["prettier"],
  "rules": {
    "no-console": "off",
    "indent": "off",
    "linebreak-style": "off",

    "import/prefer-default-export": "off",
    "no-underscore-dangle": "off",

    "prettier/prettier": [
      "error",
      {
        "trailingComma": "es5",
        "singleQuote": true,
        "printWidth": 100,
        "tabWidth": 4,
        "semi": true,
        "endOfLine": "auto"
      }
    ]
  }
}